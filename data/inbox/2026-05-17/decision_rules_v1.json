          "risk_progression": {
            "mild_ams": {"symptoms": "轻微头痛可忍，活动正常", "action": "休息+止痛药，可继续但缓升"},
            "moderate_ams": {"symptoms": "头剧痛+呕吐+乏力+协调下降", "action": "立即下撤至少500m", "grade": "inadvisable"},
            "hape": {"symptoms": "静息时呼吸困难+持续性干咳+唇色发蓝+心率加快", "action": "紧急下撤+就医+氧气", "grade": "inadvisable"},
            "hace": {"symptoms": "意识混乱+共济失调", "action": "紧急下撤+地塞米松+氧气", "grade": "inadvisable"}
