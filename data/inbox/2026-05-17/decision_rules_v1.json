    "cycling": {
      "name": "单车/骑行",
      "description": "公路骑行与山地骑行",
      "load_model": {
        "inputs": {
          "distance_km": {"type": "number", "unit": "km", "description": "骑行距离"},
          "elevation_gain_m": {"type": "number", "unit": "m", "description": "累计爬升"},
          "duration_h": {"type": "number", "unit": "h", "description": "预计用时"},
          "avg_speed_kmh": {"type": "number", "unit": "km/h", "description": "均速"},
          "temp_c": {"type": "number", "unit": "°C", "description": "平均气温"},
          "wind_kmh": {"type": "number", "unit": "km/h", "description": "平均风速"},
          "wind_gust_kmh": {"type": "number", "unit": "km/h", "description": "最大阵风"},
          "precip_mmh": {"type": "number", "unit": "mm/h", "description": "降水强度"}
        },
        "formula": {
          "base_duration_h": {"expression": "distance_km / avg_speed_kmh"},
          "elevation_penalty": {"expression": "1.0 + (elevation_gain_m / distance_km) * 0.05"},
          "adjusted_duration_h": {"expression": "base_duration_h * elevation_penalty"},
          "difficulty_score": {"expression": "MIN(100, distance_km * 0.3 + elevation_gain_m * 0.01 + adjusted_duration_h * 3.0)"},
          "score_formula": {"expression": "MAX(0.0, 100.0 - difficulty_score)"}
        },
        "score_bands": {
          "feasible": {"min": 70, "max": 100},
          "cautious": {"min": 40, "max": 69},
          "inadvisable": {"min": 0, "max": 39}
        }
      },
      "risk_model": {
        "heat_risk_thresholds": {
          "description": "骑行热风险 — 骑行风产生2-5°C降温但高湿度下有限",
          "source": "https://www.weather.gov/ffc/hichart",
          "riding_wind_chill_bonus": "effective_heat_index = heat_index_c - MIN(5.0, riding_speed_kmh * 0.1)",
          "thresholds": [
            {"heat_index_c_min": 0, "heat_index_c_max": 27, "grade": "feasible"},
            {"heat_index_c_min": 27, "heat_index_c_max": 32, "grade": "feasible", "note": "每20分钟饮水"},
            {"heat_index_c_min": 32, "heat_index_c_max": 38, "grade": "cautious", "note": "骑行风降温有效但高湿仍危险"},
            {"heat_index_c_min": 38, "heat_index_c_max": 41, "grade": "cautious", "note": "限1小时内骑行"},
            {"heat_index_c_min": 41, "heat_index_c_max": null, "grade": "inadvisable", "note": "取消骑行"}
          ]
        },
        "cold_risk_thresholds": {
          "description": "骑行风寒 — 骑行速度大幅增加风寒效应",
          "source": "https://velo.outsideonline.com/road/what-is-your-ride-or-hide-cycling-threshold/",
          "effective_wind_for_chill": {"expression": "riding_speed_kmh + headwind_kmh", "note": "骑行时有效风速=骑行速度+迎风风速"},
          "thresholds": [
            {"ambient_temp_c_min": 10, "ambient_temp_c_max": null, "grade": "feasible", "note": "合适骑行温度"},
            {"ambient_temp_c_min": 5, "ambient_temp_c_max": 10, "grade": "feasible", "note": "偏凉，需长袖+风衣"},
            {"ambient_temp_c_min": 0, "ambient_temp_c_max": 5, "grade": "cautious", "note": "寒冷+风→显著风寒，全套冬季装备"},
            {"ambient_temp_c_min": -5, "ambient_temp_c_max": 0, "grade": "cautious", "note": "严寒骑行，手脚冻僵风险高"},
            {"ambient_temp_c_min": null, "ambient_temp_c_max": -5, "grade": "inadvisable", "note": "路面结冰风险，禁止骑行"}
          ],
          "ice_risk_trigger": "IF temp_c <= 0 AND precipitation_active = true THEN ice_risk = true, grade = inadvisable"
