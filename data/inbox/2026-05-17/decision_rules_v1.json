            {"wind_kmh_min": 30, "wind_kmh_max": 40, "grade": "cautious", "description": "持续>30km/h→危险，尤其侧风"},
            {"wind_kmh_min": 40, "wind_kmh_max": 50, "grade": "cautious", "description": "下坡+侧风极端危险"},
            {"wind_kmh_min": 50, "wind_kmh_max": null, "grade": "inadvisable", "description": "阵风>50km/h取消"}
          ],
          "gust_rule": "IF wind_gust_kmh > 50 THEN grade = inadvisable",
