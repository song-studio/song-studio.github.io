            {"precip_mmh_min": 5.1, "precip_mmh_max": 15, "grade": "cautious", "description": "中雨，降速50%"},
            {"precip_mmh_min": 15.1, "precip_mmh_max": 30, "grade": "inadvisable", "description": "大雨，避雨等待"},
            {"precip_mmh_min": 30.1, "precip_mmh_max": null, "grade": "inadvisable", "description": "暴雨，取消"}
          ],
          "first_hour_oil_slick": "雨后第一小时油膜最滑，减速60%",
          "hydroplaning_risk_kmh": 80
        },
        "storm_abort_rules": {
          "source": "https://www.riderdome.com/post/top-6-reasons-why-weather-conditions-affect-motorcycle-safety",
          "lightning_30_30_rule": {
            "expression": "IF flash_to_bang_seconds <= 30 THEN find_building_shelter",
            "note": "摩托无车身法拉第笼保护",
            "grade": "inadvisable"
          },
          "hail_rule": "IF hail_detected THEN immediate_shelter",
          "thunderstorm_rule": "IF thunderstorm_forecast THEN cancel_ride"
        },
        "visibility_rules": {
          "source": "https://apps.itd.idaho.gov/apps/dmv-audio/documents/DLChapter6.pdf",
          "thresholds": [
            {"visibility_m_min": 500, "visibility_m_max": null, "grade": "feasible"},
            {"visibility_m_min": 200, "visibility_m_max": 500, "grade": "cautious", "description": "降速50%，开前后灯"},
            {"visibility_m_min": 100, "visibility_m_max": 200, "grade": "cautious", "description": "降速70%，强烈建议中止"},
            {"visibility_m_min": 0, "visibility_m_max": 100, "grade": "inadvisable", "description": "取消骑行"}
          ],
          "helmet_visor_antifog": "防雾喷剂可提升能见度约30%"
        }
      },
      "altitude_model": {
        "description": "高海拔对摩托车的影响",
        "engine_power_loss_per_1000m": 0.10,
        "engine_power_formula": {"expression": "power_at_altitude = sea_level_power * (1.0 - altitude_m / 1000 * 0.10)", "note": "自然吸气发动机"},
        "temp_drop_per_1000m_C": 6.5,
        "note": "涡轮增压发动机功率损失约5%/1000m"
      },
      "execution_rules": {
        "recommended_departure_window": {
          "rule": {"summer": "07:00-09:00", "winter": "08:00-10:00"},
          "note": "避开晨雾/结冰/早晚高峰"
        },
        "turnaround_time_rule": {
          "expression": "sunset_hour - 2.0",
          "note": "日落前2小时，摩托需更多缓冲时间"
        },
        "latest_safe_finish_rule": {
          "expression": "sunset_hour - 0.5",
          "note": "日落前30分钟"
        },
        "hydration_per_hour_l": {
          "expression": "0.3 <= x <= 0.8",
          "note": "骑行服内侧闷热，容易脱水不自知"
        },
        "electrolyte_mg_per_hour": {
          "expression": "IF temp_c > 30 THEN 200 <= x <= 600 ELSE 0",
          "note": "热天补充，冷天可不补"
        },
        "calorie_kcal_per_hour": {
          "expression": "100 <= x <= 300",
          "source": "https://us.saint.cc/blogs/journal/does-riding-a-motorcycle-burn-calories",
          "note": "远低于人力运动"
        },
        "fatigue_management": {
          "max_continuous_riding_hours": 2.0,
          "rest_break_minutes": 15,
          "max_daily_distance_km": 400,
          "max_daily_hours_inclusive_rest": 8.0,
          "source": "https://www.roadrunner.travel/articles/riding-in-cold-weather/"
        }
      },
      "gear_rules": {
        "light_kit": {
          "trigger": {"temp_c_min": 20, "temp_c_max": 40, "precip_mmh_max": 2.5, "wind_kmh_max": 28, "altitude_m_max": 2000},
          "kit_list": ["夏季骑行服(网眼)", "头盔", "手套", "骑行靴", "护膝", "防晒"]
        },
        "three_season_kit": {
          "trigger": {"temp_c_min": 10, "temp_c_max": 30, "precip_mmh_max": 10, "wind_kmh_max": 38, "altitude_m_max": 3000},
          "kit_list": ["四季骑行服(可拆内胆)", "头盔+风镜", "防水手套", "骑行靴", "雨衣", "CE护具"]
        },
        "cold_high_alt_kit": {
          "trigger": {"temp_c_min": -10, "temp_c_max": 15, "precip_mmh_max": 15, "wind_kmh_max": 55, "altitude_m_max": 5000},
          "kit_list": ["电加热骑行服/手套", "防风防水连体骑行服", "冬季头盔(防雾片)", "滑雪级手套", "防水靴+雪套", "CE2级护具"]
        }
      }
    }
  }
}
